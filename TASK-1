#include <stdio.h>
int main()
{
   float radius,area,perimeter;
   printf("Radius in cm: ");
   scanf("%f",&radius);
   area=(3.14*radius*radius);
   perimeter=(2*3.14*radius);
   printf("Area of the circle is %.1fcm^2\n",area);
   printf("perimeter of the circle is %.1fcm\n",perimeter);
   return 0;
}


