#include <stdio.h>
int main()
{
    int a;
    int b;
    printf("Enter the first value: ");
    scanf("%d",&a);
    printf("Enter the second value: ");
    scanf("%d",&b);
    printf("Addition: %d\n",a+b);
    printf("Subraction: %d\n",a-b);
    printf("Multiplication: %d\n",a*b);
    printf("Division: %d\n",a/b);
    printf("Modulus: %d\n",a%b);
    return 0;
   
}


#include <stdio.h>
int main()
{
    int a;
    printf("Enter the value: ");
    scanf("%d",&a);
    printf("The value is %d\n",a);
    printf("pre-increment: %d\n",++a);
    printf("post-increment: %d\n",a++);
    printf("%d\n",a);
    printf("pre-decrement: %d\n",--a);
    printf("post-decrement: %d\n",a--);
    printf("%d\n",a);
    return 0;
}


#include <stdio.h>
int main()
{
    float distance;
    float time;
    float speed;
    printf("Distance in km: ");
    scanf("%f",&distance);
    printf("Time in hrs: ");
    scanf("%f",&time);
    speed=distance/time;
    printf("Speed is %.1f km/h",speed);
    return 0;
}


